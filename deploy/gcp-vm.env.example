# Example env for GCP VM — copy to gcp-vm.env and source before `pm2 start`
# Public IP (optional reference only)
# VM_PUBLIC_IP=35.194.27.132

# Same-VM (recommended): loopback
CONFIG_SERVER_URL=http://127.0.0.1:8888
EUREKA_URL=http://127.0.0.1:8761/eureka

# If config-repo lives elsewhere on the VM, set absolute path in PM2 or here and wire ecosystem (see pm2/ecosystem.config.cjs)
# CONFIG_REPO_PATH=/opt/eca-cloud/config-repo

# GCP credentials (pick one)
# GOOGLE_APPLICATION_CREDENTIALS=/opt/secrets/gcp-sa.json
# On GCE, usually use the VM's attached service account — no file needed.

# Product/order Firestore & GCS (override defaults if needed)
# FIRESTORE_PROJECT_ID=buddhi-cloud
# GCS_PROJECT_ID=buddhi-cloud
# GCS_BUCKET=prod-product12
# STORAGE_PROVIDER=gcs

# Strong secrets for production (prefer not to commit these)
# JWT_SECRET=...
# And move MySQL password out of config-repo into Spring env if possible.
