# Example env for GCP VM — copy to gcp-vm.env and source before `pm2 start`
#
# Reserved static IP (project): 34.118.204.224
# - If this is the HTTP(S) load balancer: public app URL is http://34.118.204.224/ (port 80/443 on LB → gateway :8080).
# - EUREKA_URL below must reach Eureka :8761 (platform VM internal IP or same machine) — NOT the LB unless you expose :8761 on that IP.

CONFIG_SERVER_URL=http://127.0.0.1:8888

# Production: loads config-repo/application-prod.yml — defaultZone is only EUREKA_URL (no localhost).
SPRING_PROFILES_ACTIVE=prod
# Local laptop: comment out the line above so default application.yml uses 127.0.0.1 fallback.

# Eureka server URL (NOT localhost on GCP) — all services use this to register & fetch registry.
# Use platform VM IP or internal DNS; if Eureka listens on the same host as 34.118.204.224 with :8761 open:
EUREKA_URL=http://34.118.204.224:8761/eureka

# Local dev on one machine only:
# EUREKA_URL=http://127.0.0.1:8761/eureka

# If config-repo lives elsewhere on the VM, set absolute path in PM2 or here and wire ecosystem (see pm2/ecosystem.config.cjs)
# CONFIG_REPO_PATH=/opt/eca-cloud/config-repo

# GCP credentials (pick one)
# GOOGLE_APPLICATION_CREDENTIALS=/opt/secrets/gcp-sa.json
# On GCE, usually use the VM's attached service account — no file needed.

# Product/order Firestore & GCS (override defaults if needed)
# FIRESTORE_PROJECT_ID=buddhi-cloud
# GCS_PROJECT_ID=buddhi-cloud
# GCS_BUCKET=prod-product12
# STORAGE_PROVIDER=gcs

# Strong secrets for production (prefer not to commit these)
# JWT_SECRET=...
# And move MySQL password out of config-repo into Spring env if possible.
